# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=talent_pool

# AI 配置（CodingPlan / DashScope 网关）
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.6-plus

# 简历目录路径（多个路径用逗号分隔）
RESUME_DIR=D:/path/to/resumes,\\\\192.168.x.x\\简历资料夹

# 扫描间隔（秒）
SCAN_INTERVAL=300
